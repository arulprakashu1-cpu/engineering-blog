# ---------------------------------------------------------------------------
# Database (Neon / Supabase / any Postgres). Use a pooled connection string
# for the app runtime; a direct (non-pooled) URL is needed for migrations.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Optional: direct connection for `prisma migrate` (Neon/Supabase poolers).
# If your provider does not need this, you can omit it.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---------------------------------------------------------------------------
# NextAuth
# Generate a secret with: openssl rand -base64 32
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Seed admin account. The seed script reads these to create/update the admin.
# Provide EITHER a plaintext password (hashed by the seed) OR a precomputed
# bcrypt hash. The hash takes precedence if both are set.
# Generate a hash locally with: npm run hash -- "your-password"
# ---------------------------------------------------------------------------
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-in-production"
ADMIN_PASSWORD_HASH=""

# ---------------------------------------------------------------------------
# Public site URL used for sitemap / robots / OG tags. Falls back to
# NEXTAUTH_URL, then localhost.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
